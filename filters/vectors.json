{
  "version": 2,
  "note": "Frozen vectors for the filter AST v2 (docs/34, phase 3). schema.json is the shape; this file is the meaning. Four surfaces used to carry four dialects of the same idea — three Go evaluators, three PHP validators and the TypeScript mirror of the campaign builder — and they drifted because nothing pinned them together. Every implementation replays these cases: Go (internal/filters), PHP (app/Services/Filters) and TypeScript (campaign-graph.ts). Tests compare parsed structures, never bytes.",
  "semantics": {
    "structure": "groups are OR'd, the conditions inside a group are AND'd. An empty groups array — and a group with no conditions — targets everyone.",
    "absence": "absence is never a value. Every value operator is false when the key is missing, including the negative ones (is_not, not_contains, neq): only is_set / is_not_set speak about presence. is_empty matches an explicit empty list, never a missing key.",
    "case": "is / is_not / in compare exactly; contains / not_contains / starts_with / ends_with are case-insensitive.",
    "leniency": "in-memory readers coerce the operand to the condition's declared type before comparing, because /decide receives person_properties straight from the caller and they never pass through the enricher. A value that cannot be coerced does not match (and does not match the negation either).",
    "defensive": "unknown scope, type or operator never matches, in every direction. A newer panel must not make an older reader target everyone. Most documents in the `defensive` list are deliberately invalid against schema.json — the exception is the group-scope case, which is a perfectly valid v2 document that today's readers simply cannot resolve yet, and it is exactly the case the deploy order of phase 3 exists to protect.",
    "now": "cases that carry a datetime operator pin context.now so the relative operators are reproducible."
  },
  "cases": [
    {
      "name": "string is matches exactly",
      "filter": { "version": 2, "groups": [{ "conditions": [{ "scope": "person", "key": "plan", "type": "string", "op": "is", "value": "pro" }] }] },
      "context": { "person": { "plan": "pro" } },
      "expect": true
    },
    {
      "name": "string is is case sensitive",
      "filter": { "version": 2, "groups": [{ "conditions": [{ "scope": "person", "key": "plan", "type": "string", "op": "is", "value": "pro" }] }] },
      "context": { "person": { "plan": "PRO" } },
      "expect": false
    },
    {
      "name": "string is on a missing key is false",
      "filter": { "version": 2, "groups": [{ "conditions": [{ "scope": "person", "key": "plan", "type": "string", "op": "is", "value": "pro" }] }] },
      "context": { "person": {} },
      "expect": false
    },
    {
      "name": "string is coerces a numeric trait to its text form",
      "filter": { "version": 2, "groups": [{ "conditions": [{ "scope": "person", "key": "seats", "type": "string", "op": "is", "value": "5" }] }] },
      "context": { "person": { "seats": 5 } },
      "expect": true
    },
