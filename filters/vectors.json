      "context": { "person": { "plan": "free" } },
      "expect": true
    },
    {
      "name": "string is_not on a missing key is false (absence is not a value)",
      "filter": { "version": 2, "groups": [{ "conditions": [{ "scope": "person", "key": "plan", "type": "string", "op": "is_not", "value": "pro" }] }] },
      "context": { "person": {} },
      "expect": false
    },
